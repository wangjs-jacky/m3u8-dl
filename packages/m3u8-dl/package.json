{
  "name": "m3u8-dl",
  "version": "1.0.0",
  "description": "M3U8 视频下载器 - 支持 AES-128 解密、代理、时长限制",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "m3u8-dl": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "nodemon --exec ts-node src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "server": "nodemon --exec ts-node src/server.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "m3u8",
    "hls",
    "video",
    "downloader",
    "aes-128",
    "decrypt",
    "streaming",
    "cli",
    "ffmpeg"
  ],
  "author": "wangjs-jacky",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangjs-jacky/m3u8-dl.git"
  },
  "bugs": {
    "url": "https://github.com/wangjs-jacky/m3u8-dl/issues"
  },
  "homepage": "https://github.com/wangjs-jacky/m3u8-dl#readme",
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cac": "^6.7.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "global-agent": "^4.1.2",
    "https-proxy-agent": "^7.0.6",
    "m3u8-parser": "^7.1.0",
    "node-fetch": "^2.7.0",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/node-fetch": "^2.6.13",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0"
  }
}
